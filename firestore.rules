rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────
    // Helper functions
    // ─────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'sebahotelmkt@gmail.com' ||
        request.auth.token.email == 'felixblancovolpe@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Group-stage closing: 11 June 2026 21:00 UTC = 1781211600000 ms
    function isBeforeGroupDeadline() {
      return request.time.toMillis() < 1781211600000;
    }

    // Match doc inspection
    function matchExists(matchId) {
      return exists(/databases/$(database)/documents/matches/$(matchId));
    }
    function isMatchUnfinished(matchId) {
      let m = get(/databases/$(database)/documents/matches/$(matchId)).data;
      return m.isFinished == false || m.isFinished == null;
    }

    // The predicting user must have paid (paymentStatus == 'confirmed')
    function isUserPaymentConfirmed() {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return u.paymentStatus == 'confirmed';
    }

    // ─────────────────────────────────────────────────────────────
    // Default deny everything (must be FIRST so specific matches override)
    // ─────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // /admins/{adminId}
    //   Optional secondary admin grant via uid doc existence
    // ─────────────────────────────────────────────────────────────
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // /config/{settings}
    //   Public read (alias MP, buy-in, deadlines)
    // ─────────────────────────────────────────────────────────────
    match /config/{settings} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // /test/{document}
    //   Connection probe used by client on boot
    // ─────────────────────────────────────────────────────────────
    match /test/{document} {
      allow read, write: if true;
    }

    // ─────────────────────────────────────────────────────────────
    // /players/{playerId}
    //   Roster for goleador/MVP (admin-managed)
    // ─────────────────────────────────────────────────────────────
    match /players/{playerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // /matches/{matchId}
    //   Read by signed-in users, written only by admin (results)
    // ─────────────────────────────────────────────────────────────
    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // /users/{userId}
    //   Self-managed profile. User CANNOT edit paymentStatus, isAdmin,
    //   totalPoints, rank. Admins can edit everything.
    // ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && userId == request.auth.uid
                    && isValidUserOnCreate(incoming());

      allow update: if isSignedIn() && (
        isAdmin()
        || (
          userId == request.auth.uid
          && incoming().diff(existing()).affectedKeys().hasOnly([
               'fullName', 'email', 'nickname', 'whatsapp', 'photoURL', 'completionPercent',
               'paymentNotified', 'paymentNotifiedAt', 'createdAt', 'rank', 'uid'
             ])
          && (!incoming().diff(existing()).affectedKeys().hasAny(['email']) || incoming().email == request.auth.token.email)
          && isValidUserOnUpdate(incoming())
        )
      );

      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // /predictions/{predictionId}
    //   - Read own anytime; after deadline read all (Audición Transparente)
    //   - Write only own predictions, before deadline, on unfinished matches
    //   - Predictor must have paymentStatus == 'confirmed'
    //   - predictionId MUST equal `${userId}_${matchId}` to prevent dup-spam
    // ─────────────────────────────────────────────────────────────
    match /predictions/{predictionId} {

      allow read: if isSignedIn() && (
        isAdmin()
        || resource == null
        || resource.data.userId == request.auth.uid
        || !isBeforeGroupDeadline()
      );

      allow create: if isSignedIn() && (
                      isAdmin()
                      || (
                        incoming().userId == request.auth.uid
                        && isValidPrediction(incoming())
                        && isBeforeGroupDeadline()
                        && predictionId == request.auth.uid + '_' + incoming().matchId
                        && matchExists(incoming().matchId)
                        && isMatchUnfinished(incoming().matchId)
                      )
                    );

      allow update: if isSignedIn() && (
                      isAdmin()
                      || (
                        existing().userId == request.auth.uid
                        && incoming().userId == request.auth.uid
                        && incoming().matchId == existing().matchId
                        && isValidPrediction(incoming())
                        && isBeforeGroupDeadline()
                        && isMatchUnfinished(existing().matchId)
                        && incoming().diff(existing()).affectedKeys().hasOnly([
                             'homeScore', 'awayScore', 'updatedAt', 'createdAt', 'id', 'userId', 'matchId'
                           ])
                      )
                    );

      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // Validation helpers
    // ─────────────────────────────────────────────────────────────

    function isValidUserOnCreate(data) {
      // Admins must be able to auto-bootstrap their own profile with
      // paymentStatus='confirmed' and isAdmin=true on first login. Regular
      // users must enter as paymentStatus='pending', isAdmin=false.
      // The email check is safe because request.auth.token.email is set by
      // Firebase Auth — only the real owner of the address can pass it.
      let isAdminEmail = request.auth.token.email == 'sebahotelmkt@gmail.com'
                         || request.auth.token.email == 'felixblancovolpe@gmail.com';

      return data.keys().hasAll(['fullName', 'email', 'paymentStatus', 'createdAt', 'uid'])
             && data.fullName is string
             && data.fullName.size() >= 3 && data.fullName.size() <= 100
             && data.email is string
             && data.email.size() >= 3 && data.email.size() <= 100
             && data.uid == request.auth.uid
             // paymentStatus: pending for regular users, may be 'confirmed' for admin bootstrap
             && (isAdminEmail || data.paymentStatus == 'pending')
             // isAdmin: false/absent for regular users, may be true for admin bootstrap
             && (isAdminEmail || !data.keys().hasAny(['isAdmin']) || data.isAdmin == false)
             // Points MUST be 0 or absent on create (applies to everyone, even admin)
             && (!data.keys().hasAny(['totalPoints']) || data.totalPoints == 0);
    }

    function isValidUserOnUpdate(data) {
      return (data.nickname == null
              || (data.nickname is string && data.nickname.size() <= 30))
             && (data.fullName == null
                 || (data.fullName is string && data.fullName.size() >= 3 && data.fullName.size() <= 100))
             && (data.whatsapp == null
                 || (data.whatsapp is string && data.whatsapp.size() <= 30))
             // photoURL may be a base64 data URL (compressed JPEG ~256x256). 200 KB cap.
             && (data.photoURL == null
                 || (data.photoURL is string && data.photoURL.size() <= 200000));
    }

    function isValidPrediction(data) {
      return data.keys().hasAll(['userId', 'matchId', 'homeScore', 'awayScore'])
             && data.homeScore is int && data.homeScore >= 0 && data.homeScore <= 20
             && data.awayScore is int && data.awayScore >= 0 && data.awayScore <= 20
             && data.matchId is string
             && isValidId(data.matchId);
    }
  }
}
